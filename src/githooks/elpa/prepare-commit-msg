#!/bin/sh
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
SHA1=$3

[ -z "$COMMIT_SOURCE" ] || exit 0

print_staged() {
    git diff --name-only --staged --no-renames
}

print_summary() {
    git diff --summary --staged --no-renames
}

lines=( $(print_staged | sed 's/\/.*$//' | sed 's/\.signed$//' | uniq) )
pkg=$(echo "${lines[0]}" | sed 's/-[^-]*$//')
ver1=$(echo "${lines[0]}" | sed 's/^.*-//')
ver2=$(echo "${lines[1]}" | sed 's/^.*-//')

lines=( $(printf "%s\n" "${ver1}" "${ver2}" | sort -V) )
ver1=${lines[0]}
ver2=${lines[1]}

if [ -n "${pkg}" ] \
       && [ -n "${ver1}" ]
then
    if [ -n "${ver2}" ]; then
        sed -i "1iUpdate ${pkg} ${ver1} -> ${ver2}" "$COMMIT_MSG_FILE"
    else
        action="Add"
        if print_summary | head -n 1 | grep -q "delete mode"; then
            action="Delete"
        fi
        sed -i "1i${action} ${pkg} ${ver1}" "$COMMIT_MSG_FILE"
    fi
fi
